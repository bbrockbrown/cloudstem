PORT=8000
NODE_ENV=production
# Set to your EC2 public IP or domain (e.g. http://54.x.x.x or https://yourdomain.com)
FRONTEND_URL=http://YOUR_EC2_IP_OR_DOMAIN
FRONTEND_URL_DEV=http://localhost:3000

AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=cloud-stem-audio-files
SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/YOUR_ACCOUNT_ID/audio-processing-queue
DYNAMODB_TABLE_NAME=AudioProcessingJobs
# 64-character hex string (32 bytes) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_key